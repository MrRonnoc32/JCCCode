<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Jacksonville's Budget and the Property Tax Question</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Fraunces:opsz,wght@9..144,400;9..144,500;9..144,600;9..144,700;9..144,900&family=Newsreader:ital,opsz,wght@0,6..72,400;0,6..72,500;0,6..72,600;1,6..72,400&display=swap" rel="stylesheet">
<style>
  :root{
    --ink:#10100c;
    --paper:#f7f3e8;
    --paper-2:#efe9d8;
    --rule:#1a1a14;
    --teal:#0d5c54;
    --teal-deep:#063d38;
    --rust:#a8401a;
    --gold:#b7882e;
    --muted:#4a473c;
    --shadow:rgba(16,16,12,0.14);
    --safety:#0d5c54;
    --cut:#a8401a;
    --tax:#1f5673;
  }
  *{box-sizing:border-box;}
  html{scroll-behavior:smooth;}
  body{
    margin:0;
    background:var(--paper);
    color:var(--ink);
    font-family:"Newsreader",Georgia,serif;
    font-size:19px;
    line-height:1.62;
    -webkit-font-smoothing:antialiased;
  }
  /* subtle paper texture */
  body::before{
    content:"";
    position:fixed;inset:0;
    pointer-events:none;z-index:0;
    background-image:
      radial-gradient(circle at 20% 30%, rgba(183,136,46,0.04), transparent 40%),
      radial-gradient(circle at 80% 70%, rgba(13,92,84,0.04), transparent 40%);
  }
  .wrap{position:relative;z-index:1;}
  h1,h2,h3,h4{font-family:"Fraunces",Georgia,serif;line-height:1.08;margin:0;font-weight:600;}
  a{color:var(--teal);}
  a:focus-visible,button:focus-visible,input:focus-visible,[tabindex]:focus-visible{
    outline:3px solid var(--rust);
    outline-offset:3px;
  }

  /* ---------- skip link ---------- */
  .skip{
    position:absolute;left:-9999px;top:0;background:var(--ink);color:var(--paper);
    padding:12px 18px;z-index:100;font-family:"Fraunces";text-decoration:none;
  }
  .skip:focus{left:8px;top:8px;}

  /* ---------- nav ---------- */
  nav{
    position:sticky;top:0;z-index:50;
    background:var(--ink);
    border-bottom:2px solid var(--gold);
  }
  nav ul{
    display:flex;flex-wrap:wrap;gap:0;margin:0;padding:0;list-style:none;
    max-width:1180px;margin-inline:auto;
  }
  nav a{
    display:block;color:var(--paper);text-decoration:none;
    padding:14px 20px;font-family:"Fraunces";font-size:15px;font-weight:500;
    letter-spacing:0.02em;border-right:1px solid rgba(247,243,232,0.14);
  }
  nav a:hover{background:var(--teal-deep);color:#fff;}
  nav .brand{font-weight:700;color:var(--gold);background:rgba(0,0,0,0.2);}

  /* ---------- hero ---------- */
  header.hero{
    background:var(--ink);
    color:var(--paper);
    padding:90px 24px 80px;
    border-bottom:6px double var(--gold);
  }
  .hero-inner{max-width:1000px;margin-inline:auto;}
  .kicker{
    font-family:"Fraunces";text-transform:uppercase;letter-spacing:0.32em;
    font-size:13px;color:var(--gold);margin-bottom:22px;font-weight:600;
  }
  header.hero h1{
    font-size:clamp(40px,7vw,82px);font-weight:900;letter-spacing:-0.02em;
    color:var(--paper);max-width:14ch;
  }
  header.hero h1 em{font-style:italic;color:var(--gold);font-weight:500;}
  .hero-sub{
    font-size:clamp(19px,2.2vw,24px);max-width:60ch;margin-top:28px;
    color:#ddd6c2;line-height:1.5;
  }
  .hero-meta{
    margin-top:40px;display:flex;flex-wrap:wrap;gap:28px;
    font-family:"Fraunces";font-size:14px;color:#b3ac98;
    border-top:1px solid rgba(247,243,232,0.2);padding-top:24px;
  }
  .hero-meta strong{color:var(--paper);display:block;font-size:22px;font-weight:600;}

  /* ---------- sections ---------- */
  section{padding:80px 24px;border-bottom:1px solid rgba(26,26,20,0.12);}
  .inner{max-width:1080px;margin-inline:auto;}
  .sec-num{
    font-family:"Fraunces";font-size:14px;letter-spacing:0.3em;text-transform:uppercase;
    color:var(--rust);font-weight:600;margin-bottom:14px;
  }
  section h2{font-size:clamp(30px,4.5vw,52px);font-weight:700;letter-spacing:-0.01em;max-width:18ch;}
  .lead{font-size:clamp(19px,2vw,22px);max-width:62ch;margin-top:22px;color:var(--muted);}
  p{max-width:65ch;}

  /* ---------- budget overview ---------- */
  .stat-row{display:grid;grid-template-columns:repeat(auto-fit,minmax(200px,1fr));gap:2px;margin-top:48px;background:var(--rule);border:2px solid var(--rule);}
  .stat{background:var(--paper);padding:28px 24px;}
  .stat .v{font-family:"Fraunces";font-size:clamp(30px,4vw,44px);font-weight:700;line-height:1;color:var(--teal);}
  .stat .l{font-size:15px;color:var(--muted);margin-top:10px;line-height:1.35;}

  /* revenue bars */
  .barblock{margin-top:30px;}
  .bar-item{margin-bottom:18px;}
  .bar-top{display:flex;justify-content:space-between;align-items:baseline;font-size:16px;margin-bottom:6px;gap:14px;}
  .bar-top .name{font-weight:500;}
  .bar-top .amt{font-family:"Fraunces";font-weight:600;color:var(--muted);white-space:nowrap;}
  .bar-track{height:26px;background:var(--paper-2);border:1px solid var(--rule);overflow:hidden;}
  .bar-fill{height:100%;background:repeating-linear-gradient(45deg,var(--teal),var(--teal) 8px,var(--teal-deep) 8px,var(--teal-deep) 16px);}
  .bar-fill.rev{background:repeating-linear-gradient(45deg,var(--gold),var(--gold) 8px,#9c7426 8px,#9c7426 16px);}

  /* department drilldown */
  .dept-intro{margin-top:48px;}
  .dept-list{margin-top:24px;border-top:2px solid var(--rule);}
  .dept{border-bottom:1px solid rgba(26,26,20,0.18);}
  .dept-btn{
    width:100%;background:none;border:none;cursor:pointer;text-align:left;
    padding:18px 8px;display:flex;align-items:center;gap:18px;
    font-family:"Newsreader";font-size:18px;color:var(--ink);
  }
  .dept-btn:hover{background:var(--paper-2);}
  .dept-btn .chev{font-family:"Fraunces";color:var(--rust);transition:transform .2s;font-size:20px;width:18px;}
  .dept-btn[aria-expanded="true"] .chev{transform:rotate(90deg);}
  .dept-btn .dn{flex:1;font-weight:500;}
  .dept-btn .da{font-family:"Fraunces";font-weight:600;color:var(--teal);white-space:nowrap;}
  .dept-btn .tag{font-size:12px;font-family:"Fraunces";letter-spacing:0.08em;text-transform:uppercase;padding:3px 9px;border:1px solid;border-radius:2px;}
  .tag.ps{color:var(--teal);border-color:var(--teal);}
  .tag.np{color:var(--rust);border-color:var(--rust);}
  .dept-panel{padding:0 8px 22px 44px;font-size:16.5px;color:var(--muted);max-width:60ch;display:none;}
  .dept-panel.open{display:block;}
  .dept-panel .emp{font-family:"Fraunces";color:var(--ink);font-weight:600;}

  /* public safety summary group */
  .dept-summary{border-bottom:2px solid var(--rule);}
  .dept-btn.ps-summary{background:#eef4f2;}
  .dept-btn.ps-summary:hover{background:#e2ede9;}
  .dept-btn.ps-summary .dn{font-family:"Fraunces";font-weight:700;font-size:19px;}
  .dept-btn.ps-summary .da{font-size:19px;}
  .dn-sub{display:block;font-family:"Newsreader";font-weight:400;font-style:italic;font-size:13.5px;color:var(--muted);margin-top:2px;}
  .dept-group{display:none;background:#f6faf8;padding:0 0 8px;border-top:1px solid rgba(13,92,84,0.25);}
  .dept-group.open{display:block;}
  .group-note{font-size:14.5px;color:var(--muted);padding:14px 16px 6px 44px;margin:0;max-width:64ch;}
  .dept-nested{border-bottom:1px solid rgba(26,26,20,0.12);margin:0 16px;border-left:3px solid var(--teal);}
  .dept-nested:last-child{border-bottom:none;}
  .dept-nested .dept-btn{padding-left:16px;}
  .dept-nested .dept-btn .dn{font-weight:500;}

  /* ---------- proposal cards ---------- */
  .timeline{margin-top:48px;display:grid;gap:2px;background:var(--rule);border:2px solid var(--rule);}
  .tl-step{background:var(--paper);padding:26px 28px;display:grid;grid-template-columns:130px 1fr;gap:24px;align-items:start;}
  .tl-step .yr{font-family:"Fraunces";font-size:26px;font-weight:700;color:var(--rust);}
  .tl-step .yr small{display:block;font-size:13px;color:var(--muted);font-weight:400;letter-spacing:0.05em;text-transform:uppercase;}
  .tl-step .desc{font-size:17px;}
  .tl-step .desc b{font-family:"Fraunces";}
  .callout{
    margin-top:40px;background:var(--teal-deep);color:var(--paper);
    padding:34px 36px;border-left:6px solid var(--gold);
  }
  .callout h3{font-size:24px;color:var(--gold);margin-bottom:12px;}
  .callout p{color:#e3dccb;max-width:66ch;}
  .feature-grid{margin-top:42px;display:grid;grid-template-columns:repeat(auto-fit,minmax(240px,1fr));gap:24px;}
  .feature{border:2px solid var(--rule);padding:24px;background:var(--paper);}
  .feature h4{font-size:19px;margin-bottom:10px;color:var(--teal);}
  .feature p{font-size:16px;color:var(--muted);margin:0;}

  /* ---------- calculator ---------- */
  #calc{background:var(--ink);color:var(--paper);border-bottom:6px double var(--gold);}
  #calc .sec-num{color:var(--gold);}
  #calc h2{color:var(--paper);}
  #calc .lead{color:#cdc6b3;}
  .calc-shell{
    margin-top:50px;background:var(--paper);color:var(--ink);
    border:2px solid var(--gold);
  }
  .gap-ba